<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Ground Station Admin Panel — Dark</title>

<style>
/* =========================
   DARK THEME VARIABLES
   ========================= */
:root{
  --bg:#0b0f14;
  --card:#121826;
  --card-2:#0f1523;
  --text:#e5e7eb;
  --muted:#9ca3af;
  --line:#1f2937;

  --blue:#3b82f6;
  --green:#22c55e;
  --red:#ef4444;
  --yellow:#f59e0b;

  --inactive:#4b5563;
  --shadow: 0 12px 30px rgba(0,0,0,0.6);
  --radius:12px;
}

/* =========================
   BASE
   ========================= */
*{box-sizing:border-box}
body{
  margin:0;
  padding:32px;
  font-family: "Segoe UI", Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
}

.wrap{max-width:1000px;margin:auto;}
.row{display:flex;gap:16px;flex-wrap:wrap}
.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
}

/* =========================
   HEADER
   ========================= */
.header{
  flex:1 1 520px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:16px 20px;
}
.title{font-size:16px;font-weight:800;margin:0}
.meta{display:flex;gap:10px;flex-wrap:wrap}
.pill{
  padding:4px 10px;
  border-radius:999px;
  background:#0b1220;
  border:1px solid var(--line);
  font-size:12px;
  color:var(--muted);
}

/* =========================
   ADMIN CONTROLS
   ========================= */
.adminControls{
  flex:1 1 420px;
  padding:16px 20px;
}
.adminControls h3{
  margin:0 0 10px;
  font-size:12px;
  text-transform:uppercase;
  color:var(--muted);
}
.controlGrid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}
@media(max-width:900px){
  .controlGrid{grid-template-columns:1fr}
}
label{
  font-size:12px;
  color:var(--muted);
  display:block;
  margin-bottom:4px;
}
select,input{
  width:100%;
  padding:10px;
  border-radius:10px;
  border:1px solid var(--line);
  background:#0b1220;
  color:var(--text);
}

/* =========================
   MAIN LAYOUT
   ========================= */
.main{
  margin-top:18px;
  display:grid;
  grid-template-columns:2fr 1fr;
  gap:16px;
}
@media(max-width:900px){
  .main{grid-template-columns:1fr}
}

/* =========================
   TABS
   ========================= */
.tabs{
  display:flex;
  border-bottom:1px solid var(--line);
  background:#0b1220;
}
.tab{
  flex:1;
  padding:12px;
  background:none;
  border:none;
  color:var(--muted);
  font-weight:800;
  cursor:pointer;
  border-right:1px solid var(--line);
}
.tab:last-child{border-right:none}
.tab[aria-selected="true"]{
  color:var(--text);
  background:var(--card);
  box-shadow: inset 0 -3px 0 var(--blue);
}

/* =========================
   PANELS
   ========================= */
.panel{display:none;padding:18px}
.panel.active{display:block}

.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:14px;
}
@media(max-width:760px){
  .grid{grid-template-columns:1fr}
}

.section{
  background:var(--card-2);
  border:1px solid var(--line);
  border-radius:10px;
  padding:14px;
}
.section h4{
  margin:0 0 10px;
  font-size:12px;
  text-transform:uppercase;
  color:var(--muted);
}

.kv{
  display:flex;
  justify-content:space-between;
  padding:8px 0;
  border-bottom:1px dashed #1f2937;
  font-size:13px;
}
.kv:last-child{border-bottom:none}
.k{color:var(--muted)}
.v{font-weight:800}

/* =========================
   STATUS BOX
   ========================= */
.statusBox{
  margin-top:12px;
  padding:12px;
  border-radius:10px;
  border:1px solid var(--line);
  background:#0b1220;
  display:flex;
  gap:10px;
}
.dot{
  width:10px;height:10px;border-radius:50%;
  background:var(--inactive);
  margin-top:4px;
}
.dot.active{background:var(--green)}
.statusTitle{font-weight:900}
.statusMsg{font-size:13px;color:var(--muted)}

/* =========================
   BUTTONS & LINKS
   ========================= */
.actions{margin-top:12px;display:flex;gap:10px;flex-wrap:wrap}
.btn{
  padding:11px 14px;
  border-radius:10px;
  border:1px solid var(--line);
  background:#0b1220;
  color:var(--text);
  font-weight:900;
  cursor:pointer;
}
.btn.primary{background:var(--blue);border-color:var(--blue)}
.btn.danger{background:var(--red);border-color:var(--red)}
.btn.inactiveLook{
  background:#0b1220;
  color:var(--inactive);
  border-color:#1f2937;
}

.linkRow{margin-top:10px;display:flex;gap:12px;flex-wrap:wrap}
.link{
  color:var(--blue);
  font-size:13px;
  font-weight:800;
  cursor:pointer;
  text-decoration:underline;
}
.link.inactiveLook{color:var(--inactive)}

/* =========================
   LOG
   ========================= */
.logWrap{padding:14px}
.logTitle{
  margin:0 0 10px;
  font-size:12px;
  text-transform:uppercase;
  color:var(--muted);
}
.log{
  height:380px;
  overflow:auto;
  padding:10px;
  border-radius:10px;
  background:#05070c;
  border:1px solid var(--line);
  font-family: monospace;
  font-size:12px;
  white-space:pre-wrap;
}

/* =========================
   TOAST
   ========================= */
.toast{
  position:fixed;
  right:20px;
  bottom:20px;
  background:#05070c;
  color:var(--text);
  padding:12px 14px;
  border-radius:12px;
  border:1px solid var(--line);
  box-shadow:var(--shadow);
  opacity:0;
  transform:translateY(10px);
  transition:.2s;
}
.toast.show{opacity:1;transform:translateY(0)}
.toast .small{display:block;font-size:12px;color:var(--muted)}
</style>
</head>

<body>
