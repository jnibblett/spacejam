<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Ground Station Admin Interface</title>

<style>
/* =========================================================
   THEME VARIABLES
   ========================================================= */

/* ---------- DARK (default) ---------- */
:root{
  --bg:#0b0f14;
  --card:#121826;
  --card-2:#0f1523;
  --text:#e5e7eb;
  --muted:#9ca3af;
  --line:#1f2937;
  --blue:#3b82f6;
  --green:#22c55e;
  --red:#ef4444;
  --inactive:#4b5563;
  --radius:12px;
  --shadow:0 12px 30px rgba(0,0,0,.6);
}

/* ---------- LIGHT ---------- */
html[data-theme="light"]{
  --bg:#f4f6f8;
  --card:#ffffff;
  --card-2:#f9fafb;
  --text:#111827;
  --muted:#6b7280;
  --line:#e5e7eb;
  --blue:#2563eb;
  --green:#16a34a;
  --red:#dc2626;
  --inactive:#9ca3af;
  --shadow:0 10px 20px rgba(0,0,0,.12);
}

/* =========================================================
   BASE
   ========================================================= */
*{box-sizing:border-box}
body{
  margin:0;
  padding:32px;
  font-family:"Segoe UI", Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
}
.wrap{max-width:1100px;margin:auto}
.row{display:flex;gap:16px;flex-wrap:wrap}
.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
}

/* =========================================================
   HEADER
   ========================================================= */
.header{
  flex:1 1 600px;
  padding:16px 20px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
.title{font-weight:900;font-size:16px;margin:0}
.meta{display:flex;gap:10px;flex-wrap:wrap}
.pill{
  padding:4px 10px;
  border-radius:999px;
  background:var(--card-2);
  border:1px solid var(--line);
  font-size:12px;
  color:var(--muted);
}

/* =========================================================
   THEME TOGGLE
   ========================================================= */
.themeToggle{
  display:flex;
  align-items:center;
  gap:8px;
  font-size:12px;
  cursor:pointer;
  user-select:none;
}
.themeToggle input{display:none}
.switch{
  width:44px;
  height:22px;
  background:var(--line);
  border-radius:999px;
  position:relative;
}
.switch::after{
  content:"";
  width:18px;
  height:18px;
  background:var(--card);
  border-radius:50%;
  position:absolute;
  top:2px;
  left:2px;
  transition:.25s;
}
input:checked + .switch::after{left:24px}

/* =========================================================
   TABS
   ========================================================= */
.tabs{
  display:flex;
  border-bottom:1px solid var(--line);
}
.tab{
  flex:1;
  padding:12px;
  border:none;
  background:none;
  color:var(--muted);
  font-weight:800;
  cursor:pointer;
  border-right:1px solid var(--line);
}
.tab:last-child{border-right:none}
.tab[aria-selected="true"]{
  color:var(--text);
  box-shadow:inset 0 -3px 0 var(--blue);
}

/* =========================================================
   PANELS / CONTENT
   ========================================================= */
.panel{display:none;padding:18px}
.panel.active{display:block}
.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:14px;
}
.section{
  background:var(--card-2);
  border:1px solid var(--line);
  border-radius:10px;
  padding:14px;
}
.section h4{
  margin:0 0 10px;
  font-size:12px;
  text-transform:uppercase;
  color:var(--muted);
}
.kv{
  display:flex;
  justify-content:space-between;
  padding:8px 0;
  border-bottom:1px dashed var(--line);
  font-size:13px;
}
.kv:last-child{border-bottom:none}
.k{color:var(--muted)}
.v{font-weight:800}

/* =========================================================
   BUTTONS / LINKS
   ========================================================= */
.actions{margin-top:12px;display:flex;gap:10px;flex-wrap:wrap}
.btn{
  padding:10px 14px;
  border-radius:10px;
  border:1px solid var(--line);
  background:var(--card);
  color:var(--text);
  font-weight:900;
  cursor:pointer;
}
.btn.primary{background:var(--blue);border-color:var(--blue);color:#fff}
.btn.danger{background:var(--red);border-color:var(--red);color:#fff}
.btn.inactiveLook{color:var(--inactive)}

.link{
  font-size:13px;
  color:var(--blue);
  font-weight:800;
  cursor:pointer;
  text-decoration:underline;
}

/* =========================================================
   SIMPLE JS-ONLY DEMO LOGIC
   ========================================================= */
</style>
</head>

<body>
<div class="wrap">

  <!-- HEADER -->
  <div class="row">
    <div class="card header">
      <div>
        <p class="title">Ground Station Admin Interface</p>
        <div class="meta">
          <span class="pill">Logged in: name@wfc.xyz</span>
          <span class="pill">Role: Dev</span>
          <span class="pill">Team: Team_123</span>
        </div>
      </div>

      <!-- THEME TOGGLE -->
      <label class="themeToggle">
        <span>🌙</span>
        <input id="themeSwitch" type="checkbox">
        <span class="switch"></span>
        <span>☀️</span>
      </label>
    </div>
  </div>

  <!-- TABS + CONTENT -->
  <div class="card" style="margin-top:16px">
    <div class="tabs">
      <button class="tab" aria-selected="true" onclick="selectTab(0)">GS1</button>
      <button class="tab" aria-selected="false" onclick="selectTab(1)">GS2</button>
      <button class="tab" aria-selected="false" onclick="selectTab(2)">GS3</button>
      <button class="tab" aria-selected="false" onclick="selectTab(3)">GS4</button>
    </div>

    <div class="panel active">
      <div class="grid">
        <div class="section">
          <h4>Satellite Connectivity</h4>
          <div class="kv"><span class="k">Satellite Visible</span><span class="v">No</span></div>
          <div class="kv"><span class="k">Status</span><span class="v">Inactive</span></div>
          <p style="color:var(--muted);font-size:13px;margin-top:10px">
            Unable to Prepare RING Key Distribution
          </p>
        </div>

        <div class="section">
          <h4>Ground Connectivity</h4>
          <div class="kv"><span class="k">Connection</span><span class="v">None</span></div>
          <div class="actions">
            <button class="btn primary inactiveLook">Connect to GS</button>
            <button class="btn inactiveLook">Distribute Keys</button>
          </div>
          <p class="link" onclick="alert('Demo click captured')">Establish Secure Link</p>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
/* =========================================================
   TAB SWITCHING
   ========================================================= */
function selectTab(index){
  document.querySelectorAll(".tab").forEach((t,i)=>{
    t.setAttribute("aria-selected", i===index);
  });
  document.querySelectorAll(".panel").forEach((p,i)=>{
    p.classList.toggle("active", i===index);
  });
}

/* =========================================================
   THEME TOGGLE (persisted)
   ========================================================= */
const html = document.documentElement;
const toggle = document.getElementById("themeSwitch");

// load saved theme
const savedTheme = localStorage.getItem("theme") || "dark";
html.setAttribute("data-theme", savedTheme);
toggle.checked = savedTheme === "light";

// toggle handler
toggle.addEventListener("change", ()=>{
  const theme = toggle.checked ? "light" : "dark";
  html.setAttribute("data-theme", theme);
  localStorage.setItem("theme", theme);
});
</script>
</body>
</html>
