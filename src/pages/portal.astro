<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>WFC Ground Station Admin</title>

<style>
/* =========================================================
   THEME VARIABLES
   ========================================================= */
:root{
  --bg:#0b0f14;
  --card:#121826;
  --card-2:#0f1523;
  --text:#e5e7eb;
  --muted:#9ca3af;
  --line:#1f2937;
  --blue:#3b82f6;
  --green:#22c55e;
  --red:#b91c1c;
  --inactive:#4b5563;
  --radius:12px;
}

html[data-theme="light"]{
  --bg:#f4f6f8;
  --card:#ffffff;
  --card-2:#f9fafb;
  --text:#111827;
  --muted:#6b7280;
  --line:#e5e7eb;
  --blue:#2563eb;
  --green:#16a34a;
  --red:#dc2626;
  --inactive:#9ca3af;
}

*{box-sizing:border-box}
body{
  margin:0;
  font-family:"Segoe UI", Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* =========================================================
   PRIMARY NAVIGATION (RED BAR)
   ========================================================= */
.primaryNav{
  background:var(--red);
  display:flex;
  gap:6px;
  padding:10px 16px;
}
.primaryTab{
  color:#fff;
  font-weight:800;
  padding:8px 14px;
  border-radius:8px;
  cursor:pointer;
  opacity:.85;
}
.primaryTab.active{
  background:rgba(255,255,255,.25);
  opacity:1;
}

/* =========================================================
   PAGE LAYOUT
   ========================================================= */
.page{
  display:none;
  padding:24px;
}
.page.active{display:block}
.wrap{max-width:1100px;margin:auto}

/* =========================================================
   USER CONTEXT HEADER
   ========================================================= */
.header{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:16px 20px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
.meta{display:flex;gap:10px;flex-wrap:wrap}
.pill{
  padding:4px 10px;
  border-radius:999px;
  background:var(--card-2);
  border:1px solid var(--line);
  font-size:12px;
  color:var(--muted);
}

/* =========================================================
   SECONDARY NAVIGATION (GS TABS)
   ========================================================= */
.secondaryNav{
  margin-top:18px;
  border-bottom:1px solid var(--line);
  display:flex;
}
.gsTab{
  flex:1;
  padding:12px;
  text-align:center;
  font-weight:800;
  cursor:pointer;
  color:var(--muted);
}
.gsTab.active{
  color:var(--text);
  box-shadow:inset 0 -3px 0 var(--blue);
}

/* =========================================================
   CONTENT CARDS
   ========================================================= */
.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:18px;
  margin-top:18px;
}
.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:14px;
}
.section{
  background:var(--card-2);
  border:1px solid var(--line);
  border-radius:10px;
  padding:14px;
}
.section h4{
  margin:0 0 10px;
  font-size:12px;
  text-transform:uppercase;
  color:var(--muted);
}
.kv{
  display:flex;
  justify-content:space-between;
  padding:8px 0;
  border-bottom:1px dashed var(--line);
}
.kv:last-child{border-bottom:none}
.k{color:var(--muted)}
.v{font-weight:800}

/* =========================================================
   BUTTONS
   ========================================================= */
.actions{margin-top:12px;display:flex;gap:10px}
.btn{
  padding:10px 14px;
  border-radius:10px;
  border:1px solid var(--line);
  background:var(--card);
  color:var(--text);
  font-weight:900;
  cursor:pointer;
}
.btn.primary{background:var(--blue);color:#fff}
.btn.inactive{color:var(--inactive)}
</style>
</head>

<body>

<!-- ======================================================
     PRIMARY NAVIGATION (RED BAR)
     ====================================================== -->
<div class="primaryNav">
  <div class="primaryTab active" onclick="selectPrimary('home')">Home</div>
  <div class="primaryTab" onclick="selectPrimary('global')">Global View</div>
  <div class="primaryTab" onclick="selectPrimary('table')">Table View</div>
  <div class="primaryTab" onclick="selectPrimary('users')">Manage WFC Users</div>
  <div class="primaryTab" onclick="selectPrimary('logout')">Logout</div>
</div>

<!-- ======================================================
     PAGE: HOME
     ====================================================== -->
<div id="home" class="page active">
  <div class="wrap">

    <!-- USER CONTEXT HEADER -->
    <div class="header">
      <div class="meta">
        <span class="pill">Logged in: name@wfc.xyz</span>
        <span class="pill">Role: Dev</span>
        <span class="pill">Team: Team_123</span>
      </div>
    </div>

    <!-- SECONDARY NAVIGATION (GS CONTEXT) -->
    <div class="secondaryNav">
      <div class="gsTab active" onclick="selectGS(this)">GS1</div>
      <div class="gsTab" onclick="selectGS(this)">GS2</div>
      <div class="gsTab" onclick="selectGS(this)">GS3</div>
      <div class="gsTab" onclick="selectGS(this)">GS4</div>
    </div>

    <!-- GS PANEL -->
    <div class="card">
      <div class="grid">

        <!-- SATELLITE CONNECTIVITY -->
        <div class="section">
          <h4>Satellite Connectivity</h4>
          <div class="kv"><span class="k">Satellite Visible</span><span class="v">No</span></div>
          <div class="kv"><span class="k">Status</span><span class="v">Inactive</span></div>
        </div>

        <!-- GROUND CONNECTIVITY -->
        <div class="section">
          <h4>Ground Connectivity</h4>
          <div class="kv"><span class="k">Connection</span><span class="v">None</span></div>
          <div class="actions">
            <button class="btn primary inactive">Connect to GS</button>
            <button class="btn inactive">Distribute Keys</button>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- ======================================================
     PAGE: GLOBAL VIEW
     ====================================================== -->
<div id="global" class="page">
  <div class="wrap card">
    <h2>Global View</h2>
    <p>System-wide visibility across all GS and satellites.</p>
  </div>
</div>

<!-- ======================================================
     PAGE: TABLE VIEW
     ====================================================== -->
<div id="table" class="page">
  <div class="wrap card">
    <h2>Table View</h2>
    <p>Tabular representation of GS and satellite state.</p>
  </div>
</div>

<!-- ======================================================
     PAGE: MANAGE USERS
     ====================================================== -->
<div id="users" class="page">
  <div class="wrap card">
    <h2>Manage WFC Users</h2>
    <p>User accounts, roles, and permissions.</p>
  </div>
</div>

<!-- ======================================================
     PAGE: LOGOUT
     ====================================================== -->
<div id="logout" class="page">
  <div class="wrap card">
    <h2>Logout</h2>
    <p>You have exited the admin interface.</p>
  </div>
</div>

<script>
/* =========================================================
   PRIMARY NAVIGATION LOGIC
   ========================================================= */
function selectPrimary(page){
  document.querySelectorAll('.primaryTab').forEach(t=>t.classList.remove('active'));
  event.target.classList.add('active');

  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(page).classList.add('active');
}

/* =========================================================
   SECONDARY (GS) NAVIGATION LOGIC
   ========================================================= */
function selectGS(el){
  document.querySelectorAll('.gsTab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
}
</script>

</body>
</html>
``
