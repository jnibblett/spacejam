<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Connect to WFC-maingnd</title>

  <style>
    :root{
      --aqua:#37e9ef;
      --panel:#c9f8ff;
      --title:#5b5bd6;
      --heading:#6a7fd8;
      --ink:#111;
      --muted:#666;
      --border: 1px solid rgba(0,0,0,.25);
      --shadow: 0 2px 0 rgba(0,0,0,.25);

      --btnTop:#cfe0ff;
      --btnBottom:#a7c4ff;
      --btnBorder:#3b57a5;

      --teamBar:#1b4c98;
      --danger:#ff0000;
      --ok:#1e7a1e;
    }

    *{ box-sizing:border-box; }
    body{
      margin:0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background:#fff;
      color:var(--ink);
    }

    .topbar{
      width:min(980px, 96vw);
      margin:24px auto 18px;
      background:var(--aqua);
      border-radius:2px;
      text-align:center;
      padding:10px 12px;
      box-shadow:var(--shadow);
    }
    .topbar h1{
      margin:0;
      font-size:22px;
      font-weight:500;
      color:var(--title);
      letter-spacing:.2px;
    }

    .wrap{
      width:min(900px, 96vw);
      margin:0 auto 28px;
    }

    .stateTitle{
      text-align:center;
      font-size:24px;
      font-weight:500;
      color:var(--heading);
      margin:10px 0 16px;
    }

    .panel{
      background:var(--panel);
      border:var(--border);
      width:100%;
      max-width:520px;
      margin:0 auto;
      padding:18px 18px 12px;
    }

    .kicker{
      font-weight:800;
      font-size:22px;
      margin:0 0 10px;
    }

    .satBlock{
      display:grid;
      grid-template-columns: 1fr auto;
      gap:12px 16px;
      align-items:center;
      margin-bottom:10px;
    }

    .satLabel{
      font-size:26px;
      font-weight:700;
      margin:0;
      line-height:1.1;
    }
    .satLabel .none{
      color:var(--danger);
      font-weight:800;
    }
    .satLabel .ok{
      color:var(--ok);
      font-weight:800;
    }

    .subLabel{
      font-size:16px;
      font-weight:600;
      color:#222;
    }

    .progress{
      width:200px;
      height:16px;
      border:var(--border);
      background:#efefef;
      position:relative;
      overflow:hidden;
      box-shadow: inset 0 1px 0 rgba(0,0,0,.1);
    }
    .progress > span{
      display:block;
      height:100%;
      width:40%;
      background:linear-gradient(#a7f0a7, #4cc54c);
      transition: width .35s ease;
    }

    .btn{
      display:inline-block;
      padding:10px 12px;
      background:linear-gradient(var(--btnTop), var(--btnBottom));
      border:2px solid var(--btnBorder);
      border-radius:3px;
      color:#000;
      font-weight:600;
      cursor:pointer;
      box-shadow: var(--shadow);
      text-align:center;
      min-width:200px;
      user-select:none;
      text-decoration:none;
    }
    .btn.secondary{
      min-width:160px;
      padding:8px 12px;
    }
    .btn.danger{
      background:linear-gradient(#ffd6d6, #ffaaaa);
      border-color:#a53b3b;
    }
    .btn:active{ transform:translateY(1px); }

    .btn[aria-disabled="true"]{
      background:#e6e6e6;
      border-color:#999;
      color:#777;
      cursor:not-allowed;
      box-shadow:none;
      transform:none;
      pointer-events:none;
    }

    .sectionTitle{
      font-size:22px;
      font-weight:800;
      margin:14px 0 8px;
    }

    .teamBar{
      margin:14px -18px 8px;
      padding:8px 16px;
      background:var(--teamBar);
      color:#fff;
      font-weight:700;
      letter-spacing:.2px;
      display:flex;
      justify-content:space-between;
      gap:10px;
      flex-wrap:wrap;
    }

    .footerLine{
      margin-top:12px;
      font-size:22px;
      font-weight:500;
    }

    .meta{
      font-size:13px;
      color:var(--muted);
      margin-top:8px;
    }

    /* Simple “state” helpers */
    .hidden{ display:none !important; }
  </style>
</head>

<body>
  <header class="topbar">
    <h1>Connect to WFC-maingnd</h1>
  </header>

  <main class="wrap">

    <!-- This title changes with state -->
    <div class="stateTitle" id="stateTitle">Without any active connection</div>

    <div class="panel" id="panel"
         data-state="inactive"
         data-user="name@wfc.xyz"
         data-team="-"
         data-visible-station="None">

      <div class="kicker">Satellite visible to</div>

      <div class="satBlock">
        <!-- Station label swaps between None and GS1 (or later: real station) -->
        <div class="satLabel" id="stationLabel">
          <span class="none">None</span>
        </div>

        <!-- ACTION BUTTON swaps between Connect and “Unable” or “Disconnect” -->
        <button class="btn" id="primaryBtn" type="button">
          Connect to GS1<br/>for RING Key<br/>Distribution
        </button>

        <div class="subLabel">Visible for</div>
        <div class="progress" aria-label="Visible for progress">
          <span id="visBar" style="width:45%"></span>
        </div>
      </div>

      <!-- In active state we show “Ground Connectivity” and a Disconnect control -->
      <div id="groundBlock" class="hidden">
        <div class="sectionTitle">Ground Connectivity</div>
        <button class="btn secondary" id="connectGsBtn" type="button">Connect to GS</button>
      </div>

      <!-- Team bar is shown in inactive state (to match your mock) -->
      <div class="teamBar" id="teamBar">
        <div>Team: <span id="teamName">-</span></div>
        <div id="sessionHint" class="meta" style="color:#d7e6ff;">
          Status: Disconnected
        </div>
      </div>

      <!-- Disconnect button only visible when active -->
      <button class="btn danger hidden" id="disconnectBtn" type="button">
        Disconnect
      </button>

      <div class="footerLine">Logged in: <span id="userLabel">name@wfc.xyz</span></div>
      <div class="meta" id="metaLine">Tip: Click “Connect…” to simulate an active session.</div>
    </div>
  </main>

  <script>
    // --- Simple state machine (inactive <-> active) ---
    const stateTitle   = document.getElementById('stateTitle');
    const panel        = document.getElementById('panel');
    const stationLabel = document.getElementById('stationLabel');
    const primaryBtn   = document.getElementById('primaryBtn');
    const disconnectBtn= document.getElementById('disconnectBtn');
    const groundBlock  = document.getElementById('groundBlock');
    const teamBar      = document.getElementById('teamBar');
    const sessionHint  = document.getElementById('sessionHint');
    const visBar       = document.getElementById('visBar');
    const metaLine     = document.getElementById('metaLine');

    // You can change these defaults later (or populate from real telemetry)
    const ACTIVE_STATION = 'GS1';

    function setInactive(){
      panel.dataset.state = 'inactive';
      panel.dataset.visibleStation = 'None';
      stateTitle.textContent = 'Without any active connection';

      stationLabel.innerHTML = '<span class="none">None</span>';

      // Primary button in inactive state acts as "Connect"
      primaryBtn.classList.remove('hidden');
      primaryBtn.removeAttribute('aria-disabled');
      primaryBtn.textContent = '';
      primaryBtn.innerHTML = 'Connect to ' + ACTIVE_STATION + '<br/>for RING Key<br/>Distribution';

      // Hide active-only controls
      disconnectBtn.classList.add('hidden');
      groundBlock.classList.add('hidden');

      // Show team bar like your “inactive” mock
      teamBar.classList.remove('hidden');
      sessionHint.textContent = 'Status: Disconnected';

      // Progress bar (example)
      visBar.style.width = '45%';

      metaLine.textContent = 'Tip: Click “Connect…” to simulate an active session.';
    }

    function setActive(){
      panel.dataset.state = 'active';
      panel.dataset.visibleStation = ACTIVE_STATION;
      stateTitle.textContent = 'With Active connection';

      stationLabel.innerHTML = ACTIVE_STATION; // looks like “GS1” in your mock

      // When active, we keep the RING button (optional) and show Disconnect
      primaryBtn.classList.remove('hidden');
      primaryBtn.innerHTML = 'Connect to ' + ACTIVE_STATION + '<br/>for RING Key<br/>Distribution';

      disconnectBtn.classList.remove('hidden');
      groundBlock.classList.remove('hidden');

      // Hide team bar in active state (your left mock didn’t show it)
      teamBar.classList.add('hidden');

      // Progress bar (example)
      visBar.style.width = '60%';

      metaLine.textContent = 'Active session simulated. Click “Disconnect” to return to inactive.';
    }

    // Click to connect: toggle to active
    primaryBtn.addEventListener('click', () => {
      if (panel.dataset.state === 'inactive') setActive();
      else {
        // In active state, primary button could trigger “RING Key Distribution”
        alert('RING Key Distribution action (placeholder).');
      }
    });

    // Click to disconnect: toggle to inactive
    disconnectBtn.addEventListener('click', setInactive);

    // Initialize view
    setInactive();
  </script>
</body>
</html>
