<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Satellite Admin Panel</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f8;
      margin: 0;
      padding: 40px;
    }

    .admin-container {
      max-width: 420px;
      margin: auto;
      background: #ffffff;
      border-radius: 8px;
      padding: 24px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    h1 {
      margin-top: 0;
      font-size: 20px;
      text-align: center;
    }

    .status-box {
      margin: 20px 0;
      padding: 16px;
      border-radius: 6px;
      text-align: center;
      font-weight: bold;
    }

    .connected {
      background: #e6f6ec;
      color: #1f7a3f;
      border: 1px solid #1f7a3f;
    }

    .disconnected {
      background: #fdeaea;
      color: #a12b2b;
      border: 1px solid #a12b2b;
    }

    .details {
      text-align: center;
      margin-bottom: 20px;
      font-size: 14px;
      color: #555;
    }

    button {
      width: 100%;
      padding: 12px;
      font-size: 16px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
    }

    .connect-btn {
      background: #0078d4;
      color: white;
    }

    .disconnect-btn {
      background: #a80000;
      color: white;
    }

    button:hover {
      opacity: 0.9;
    }

    .footer {
      margin-top: 20px;
      font-size: 12px;
      text-align: center;
      color: #888;
    }
  </style>
</head>
<body>

  <div class="admin-container">
    <h1>Satellite Admin Interface</h1>

    <div id="statusBox" class="status-box disconnected">
      No Active Connection
    </div>

    <div id="details" class="details">
      Not connected to any Ground Station
    </div>

    <button id="actionButton" class="connect-btn" onclick="toggleConnection()">
      Connect to GS1
    </button>

    <div class="footer">
      Logged in as: admin@wfc.xyz
    </div>
  </div>

  <script>
    let connected = false;
    let connectedGS = "GS1";

    function toggleConnection() {
      connected = !connected;

      const statusBox = document.getElementById("statusBox");
      const details = document.getElementById("details");
      const button = document.getElementById("actionButton");

      if (connected) {
        statusBox.textContent = "Connected";
        statusBox.className = "status-box connected";

        details.textContent = "Connected to " + connectedGS;

        button.textContent = "Disconnect";
        button.className = "disconnect-btn";
      } else {
        statusBox.textContent = "No Active Connection";
        statusBox.className = "status-box disconnected";

        details.textContent = "Not connected to any Ground Station";

        button.textContent = "Connect to " + connectedGS;
        button.className = "connect-btn";
      }
    }
  </script>

</body>
</html>
``
