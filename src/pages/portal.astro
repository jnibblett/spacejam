<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>WFC Ground Station Admin</title>

<style>
/* ===================== THEME ===================== */
:root{
  --bg:#0b0f14;
  --card:#121826;
  --card-2:#0f1523;
  --text:#e5e7eb;
  --muted:#9ca3af;
  --line:#1f2937;
  --blue:#3b82f6;
  --green:#22c55e;
  --red:#b91c1c;
  --amber:#f59e0b;
  --inactive:#4b5563;
  --radius:12px;
}
html[data-theme="light"]{
  --bg:#f4f6f8;
  --card:#ffffff;
  --card-2:#f9fafb;
  --text:#111827;
  --muted:#6b7280;
  --line:#e5e7eb;
  --blue:#2563eb;
  --green:#16a34a;
  --red:#dc2626;
  --amber:#d97706;
  --inactive:#9ca3af;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:"Segoe UI", Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
  padding-bottom:56px;
}

/* ===================== PRIMARY NAV ===================== */
.primaryNav{
  background:var(--red);
  display:flex;
  gap:6px;
  padding:10px 16px;
  position:sticky;
  top:0;
  z-index:10;
}
.primaryTab{
  color:#fff;
  font-weight:800;
  padding:8px 14px;
  border-radius:8px;
  cursor:pointer;
  opacity:.85;
}
.primaryTab.active{
  background:rgba(255,255,255,.25);
  opacity:1;
}
.primaryTab.disabled{
  opacity:.4;
  cursor:not-allowed;
  text-decoration:line-through;
}

/* ===================== PAGE ===================== */
.page{display:none;padding:24px}
.page.active{display:block}
.wrap{max-width:1150px;margin:auto}

/* ===================== COMMON UI ===================== */
.header{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:16px;
  margin-bottom:16px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
.meta{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.pill{
  padding:4px 10px;
  border-radius:999px;
  background:var(--card-2);
  border:1px solid var(--line);
  font-size:12px;
  color:var(--muted);
}

.secondaryNav{
  display:flex;
  border-bottom:1px solid var(--line);
  margin-bottom:16px;
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  overflow:hidden;
}
.gsTab{
  flex:1;
  text-align:center;
  padding:12px;
  font-weight:900;
  cursor:pointer;
  color:var(--muted);
}
.gsTab.active{
  color:var(--text);
  box-shadow:inset 0 -3px 0 var(--blue);
}

.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:18px;
  margin-bottom:16px;
}
.section{
  background:var(--card-2);
  border:1px solid var(--line);
  border-radius:10px;
  padding:14px;
}
.section h4{
  margin:0 0 10px;
  font-size:12px;
  text-transform:uppercase;
  color:var(--muted);
}

.btn{
  padding:10px 14px;
  border-radius:10px;
  border:1px solid var(--line);
  background:var(--card);
  color:var(--text);
  font-weight:900;
  cursor:pointer;
}
.btn.primary{background:var(--blue);color:#fff}
.btn.danger{background:var(--red);color:#fff}

/* ===================== LOG ===================== */
.logBox{
  height:520px;
  overflow:auto;
  background:var(--card-2);
  border:1px solid var(--line);
  border-radius:10px;
  padding:10px;
  font-family:monospace;
  font-size:12px;
  white-space:pre-wrap;
}
.logTools{display:flex;gap:10px;margin-top:10px}

/* ===================== REV BAR ===================== */
.revBar{
  position:fixed;
  left:0;right:0;bottom:0;
  height:56px;
  background:var(--card);
  border-top:1px solid var(--line);
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 16px;
}
.revItem{
  font-size:12px;
  color:var(--muted);
  background:var(--card-2);
  border:1px solid var(--line);
  padding:6px 10px;
  border-radius:999px;
}
.revLink{
  font-size:12px;
  color:var(--blue);
  font-weight:900;
  cursor:pointer;
  text-decoration:underline;
}
/* =========================================================
   RESPONSIVE LAYOUT — ADDITIVE ONLY
   (No structure or logic changes)
   ========================================================= */

/* ---------- Tablets & smaller laptops ---------- */
@media (max-width: 1024px) {

  .wrap {
    max-width: 100%;
  }

  .row {
    grid-template-columns: 1fr;
  }

  .grid {
    grid-template-columns: 1fr;
  }

  .actions {
    flex-wrap: wrap;
  }

  .secondaryNav {
    overflow-x: auto;
  }

  .gsTab {
    min-width: 120px;
    white-space: nowrap;
  }

  table {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
  }
}

/* ---------- Mobile ---------- */
@media (max-width: 640px) {

  body {
    padding-bottom: 72px; /* room for revision bar */
  }

  .primaryNav {
    flex-wrap: wrap;
    gap: 4px;
  }

  .primaryTab {
    padding: 6px 10px;
    font-size: 13px;
  }

  .header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .meta {
    gap: 6px;
  }

  .pill {
    font-size: 11px;
  }

  .secondaryNav {
    border-radius: 10px;
  }

  .card {
    padding: 14px;
  }

  .section {
    padding: 12px;
  }

  .btn {
    width: 100%;
  }

  .logBox {
    height: 360px;
  }

  .revBar {
    flex-direction: column;
    height: auto;
    padding: 10px;
    gap: 6px;
  }
}
``
</style>
</head>

<body>

<!-- ================= PRIMARY NAV ================= -->
<div class="primaryNav">
  <div id="nav-home" class="primaryTab active" onclick="goPage('home')">Home</div>
  <div id="nav-global" class="primaryTab" onclick="goPage('global')">Global View</div>
  <div id="nav-table" class="primaryTab" onclick="goPage('table')">Table View</div>
  <div id="nav-users" class="primaryTab" onclick="goPage('users')">Manage WFC Users</div>
  <div id="nav-logs" class="primaryTab" onclick="goPage('logs')">Logs</div>
  <div id="nav-logout" class="primaryTab" onclick="goPage('logout')">Logout</div>
</div>

<!-- ================= HOME ================= -->
<div id="page-home" class="page active">
  <div class="wrap">
    <div class="header">
      <div class="meta">
        <span class="pill">Logged in: name@wfc.xyz</span>
        <span class="pill">Role: Dev</span>
        <span class="pill">Team: Team_123</span>
      </div>
    </div>

    <div class="secondaryNav">
      <div class="gsTab active" onclick="selectGS('GS1',this)">GS1</div>
      <div class="gsTab" onclick="selectGS('GS2',this)">GS2</div>
      <div class="gsTab" onclick="selectGS('GS3',this)">GS3</div>
      <div class="gsTab" onclick="selectGS('GS4',this)">GS4</div>
    </div>

    <div class="card">
      <div class="section">
        <h4>Home View</h4>
        <p>This remains your GS operational workspace.</p>
      </div>
    </div>
  </div>
</div>

<!-- ================= GLOBAL ================= -->
<div id="page-global" class="page">
  <div class="wrap">
    <div class="card">
      <h2>Global View</h2>
      <p>This page summarizes fleet‑wide GS and satellite state.</p>
      <p><b>Click Home</b> in the red bar to return.</p>
    </div>
  </div>
</div>

<!-- ================= TABLE ================= -->
<div id="page-table" class="page">
  <div class="wrap">
    <div class="card">
      <h2>Table View</h2>
      <p>Tabular system representation.</p>
    </div>
  </div>
</div>

<!-- ================= USERS ================= -->
<div id="page-users" class="page">
  <div class="wrap">
    <div class="card">
      <h2>Manage WFC Users</h2>
      <p>Admin‑only user management view.</p>
    </div>
  </div>
</div>

<!-- ================= LOGS ================= -->
<div id="page-logs" class="page">
  <div class="wrap">
    <div class="card">
      <h2>Audit / Activity Logs</h2>
      <div id="logBox" class="logBox"></div>
      <div class="logTools">
        <button class="btn" onclick="clearLog()">Clear Log</button>
        <button class="btn" onclick="exportLog()">Export Log</button>
      </div>
    </div>
  </div>
</div>

<!-- ================= LOGOUT ================= -->
<div id="page-logout" class="page">
  <div class="wrap">
    <div class="card">
      <h2>Logout</h2>
      <button class="btn primary" onclick="goPage('home')">Return Home</button>
    </div>
  </div>
</div>

<!-- ================= REV BAR ================= -->
<div class="revBar">
  <span class="revItem">Revision 1 — <span id="revTime"></span></span>
  <span class="revLink" onclick="goPage('home')">Home</span>
</div>

<script>
/* ================= STATE ================= */
const state={log:[]};

/* ================= LOG ================= */
function stamp(){return new Date().toLocaleString()}
function logEvent(msg){
  state.log.unshift(`[${stamp()}] ${msg}`);
  renderLog();
}
function renderLog(){
  const box=document.getElementById("logBox");
  if(box) box.textContent=state.log.join("\n");
}
function clearLog(){state.log=[];renderLog()}
function exportLog(){
  navigator.clipboard?.writeText(state.log.join("\n"));
  alert("Log copied to clipboard");
}

/* ================= NAV ================= */
function goPage(page){
  document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
  document.getElementById("page-"+page).classList.add("active");
  document.querySelectorAll(".primaryTab").forEach(t=>t.classList.remove("active"));
  document.getElementById("nav-"+page).classList.add("active");
  logEvent("Navigate to "+page);
}

/* ================= GS ================= */
function selectGS(gs,el){
  document.querySelectorAll(".gsTab").forEach(t=>t.classList.remove("active"));
  el.classList.add("active");
  logEvent("Select GS "+gs);
}

/* ================= INIT ================= */
document.getElementById("revTime").textContent=stamp();
logEvent("UI loaded on Cloudflare Pages–compatible build");
</script>

</body>
</html>
